{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteImmutableDeployArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": "arn:aws:s3:::observation-prod-deploy-artifacts-491013322019-ap-northeast-2/portal/*"
    },
    {
      "Sid": "ListDeployArtifactPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::observation-prod-deploy-artifacts-491013322019-ap-northeast-2",
      "Condition": {
        "StringLike": {
          "s3:prefix": "portal/*"
        }
      }
    },
    {
      "Sid": "LocateDeployArtifactBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucketMultipartUploads"
      ],
      "Resource": "arn:aws:s3:::observation-prod-deploy-artifacts-491013322019-ap-northeast-2"
    },
    {
      "Sid": "SendRunCommandToPortalInstance",
      "Effect": "Allow",
      "Action": "ssm:SendCommand",
      "Resource": [
        "arn:aws:ec2:ap-northeast-2:491013322019:instance/i-06defdb40c40905d9",
        "arn:aws:ssm:ap-northeast-2::document/AWS-RunShellScript"
      ]
    },
    {
      "Sid": "ReadRunCommandResult",
      "Effect": "Allow",
      "Action": [
        "ssm:GetCommandInvocation",
        "ssm:ListCommandInvocations"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DescribeDeploymentTarget",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*"
    }
  ]
}
