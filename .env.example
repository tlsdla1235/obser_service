# Observation Portal environment example.
#
# 이 파일은 Git 추적되는 템플릿이다. 실제 secret 값은 `.env`, `.private/*`,
# GitHub Secrets, AWS SSM Parameter Store에만 둔다.

###############################################################################
# 공통 profile 선택
###############################################################################

# local / ci / prod 중 하나를 명시한다. 운영은 prod를 기본값으로 켜지 않는다.
SPRING_PROFILES_ACTIVE=local


###############################################################################
# Portal server / proxy
###############################################################################

SERVER_PORT=8080

# Nginx reverse proxy 뒤의 prod profile에서 사용한다. local에서는 보통 비워둔다.
SERVER_FORWARD_HEADERS_STRATEGY=


###############################################################################
# PostgreSQL datasource
###############################################################################

SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=


###############################################################################
# GitHub OAuth App
###############################################################################

# local은 개발용 OAuth App, prod는 운영용 OAuth App을 별도로 사용한다.
PORTAL_AUTH_GITHUB_CLIENT_ID=
PORTAL_AUTH_GITHUB_CLIENT_SECRET=
PORTAL_AUTH_GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
PORTAL_AUTH_GITHUB_HOMEPAGE_URL=http://localhost:8080/dashboard/


###############################################################################
# Service token / OAuth state signing
###############################################################################

# prod profile에서는 두 값 모두 비어 있으면 startup이 실패한다.
PORTAL_AUTH_SERVICE_TOKEN_SIGNING_KEY=
PORTAL_AUTH_OAUTH_STATE_SIGNING_KEY=


###############################################################################
# SQS buffered ingest
###############################################################################

# local 기본은 direct가 안전하다. 실제 SQS 또는 LocalStack 검증 때만 sqs로 바꾼다.
PORTAL_INGEST_BUFFER_MODE=direct
PORTAL_INGEST_BUFFER_MESSAGE_SIZE_LIMIT_BYTES=1048576
PORTAL_INGEST_BUFFER_PUBLISHER_TIMEOUT=3s
PORTAL_INGEST_BUFFER_SQS_QUEUE_URL=
PORTAL_INGEST_BUFFER_SQS_ENDPOINT_OVERRIDE=

# worker는 SQS mode에서만 켠다.
PORTAL_INGEST_BUFFER_WORKER_ENABLED=false
PORTAL_INGEST_BUFFER_WORKER_DLQ_URL=
PORTAL_INGEST_BUFFER_WORKER_LONG_POLL_SECONDS=20
PORTAL_INGEST_BUFFER_WORKER_MAX_MESSAGES_PER_POLL=10
PORTAL_INGEST_BUFFER_WORKER_VISIBILITY_TIMEOUT=60s
PORTAL_INGEST_BUFFER_WORKER_MAX_RECEIVE_COUNT=5
PORTAL_INGEST_BUFFER_WORKER_MAX_BATCH_SIZE=10
PORTAL_INGEST_BUFFER_WORKER_MAX_BATCH_AGE=2s


###############################################################################
# AWS SDK
###############################################################################

AWS_REGION=ap-northeast-2
AWS_DEFAULT_REGION=ap-northeast-2

# local에서 실제 AWS credential을 써야 할 때만 `.env`에 입력한다.
# prod에서는 장기 access key 대신 EC2 instance profile을 사용한다.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


###############################################################################
# Local smoke helpers
###############################################################################

OBSERVATION_PORTAL_BASE_URL=http://localhost:8080
OBSERVATION_SMOKE_SERVICE_PORT=8081
OBSERVATION_SMOKE_INSTANCE=observation-smoke-local-1
OBSERVATION_SMOKE_PROJECT_KEY=

ECC_ENDPOINT_SMOKE_SERVICE_PORT=8082
ECC_ENDPOINT_SMOKE_INSTANCE=ecc-endpoint-smoke-local-1
ECC_ENDPOINT_SMOKE_PROJECT_KEY=
