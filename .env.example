# SQS buffered ingest profile example.
# 실제 access key 값은 이 파일에 넣지 말고 로컬 `.env`에만 둔다.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_DEFAULT_REGION=ap-northeast-2

PORTAL_INGEST_BUFFER_MODE=sqs
PORTAL_INGEST_BUFFER_MESSAGE_SIZE_LIMIT_BYTES=1048576
PORTAL_INGEST_BUFFER_PUBLISHER_TIMEOUT=3s
PORTAL_INGEST_BUFFER_SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/491013322019/observation-dev-metric-bucket-ingest
PORTAL_INGEST_BUFFER_SQS_ENDPOINT_OVERRIDE=

# Story 12.3 worker 구현 때 사용할 예정인 consumer/DLQ 설정 후보.
PORTAL_INGEST_BUFFER_WORKER_ENABLED=true
PORTAL_INGEST_BUFFER_WORKER_DLQ_URL=https://sqs.ap-northeast-2.amazonaws.com/491013322019/observation-dev-metric-bucket-ingest-dlq
PORTAL_INGEST_BUFFER_WORKER_LONG_POLL_SECONDS=20
PORTAL_INGEST_BUFFER_WORKER_MAX_MESSAGES_PER_POLL=10
PORTAL_INGEST_BUFFER_WORKER_VISIBILITY_TIMEOUT=60s
PORTAL_INGEST_BUFFER_WORKER_MAX_RECEIVE_COUNT=5
PORTAL_INGEST_BUFFER_WORKER_MAX_BATCH_SIZE=10
PORTAL_INGEST_BUFFER_WORKER_MAX_BATCH_AGE=2s
